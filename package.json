{
  "name": "cruzy-web",
  "version": "1.0.0",
  "description": "Cruzy frontend and backend",
  "main": "cruzy-backend/server.js",
  "scripts": {
    "backend": "node cruzy-backend/server.js",
    "backend:dev": "node --watch cruzy-backend/server.js",
    "frontend": "vite --host 127.0.0.1 --port 5173 cruzy-frontend",
    "frontend:build": "vite build cruzy-frontend",
    "frontend:preview": "vite preview --host 127.0.0.1 --port 4173 cruzy-frontend",
    "start:backend": "node cruzy-backend/server.js",
    "start": "npm run start:backend",
    "dev": "npm run backend:dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.4",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14"
  }
}
